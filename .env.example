# App
NODE_ENV=development

# Backend
PORT=4000
JWT_SECRET=your_jwt_secret_here

# Database
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AWS / Bedrock
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
# Telephony provider — "twilio" is active; "exotel" is commented out
TELEPHONY_PROVIDER=twilio

# Twilio (active provider)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Exotel (future provider — see exotel-provider.ts to activate)
# Credentials: Exotel Dashboard → Settings → API Settings
# EXOTEL_API_KEY=your_exotel_api_key
# EXOTEL_API_TOKEN=your_exotel_api_token
# EXOTEL_ACCOUNT_SID=your_exotel_account_sid
# EXOTEL_CALLER_ID=your_dlt_registered_virtual_number
# Singapore cluster: api.exotel.com | Mumbai/India cluster: api.in.exotel.com
# EXOTEL_SUBDOMAIN=api.in.exotel.com

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# Frontend
VITE_API_URL=http://localhost:4000

# Voice Agent
VOICE_AGENT_PORT=4001
VOICE_AGENT_URL=https://your-ngrok-url.ngrok-free.app

# Streaming STT (Deepgram) — required for real-time transcription
# Get your key at https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# Redis — optional, for multi-instance session sharing
# REDIS_URL=redis://localhost:6379
